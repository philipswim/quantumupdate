ErrorText = %B3Error.Text%

[Button4]
SetupLabel = %B4SetupLabel.Text%
LabelRectValue = 340*370*485*885
SetupProgram = \SW\QuantumSwimming  6.1.24163.0.msi**
SetupWindow = QuantumAQ Swimming setup Wizard
TestFile = \SW\QuantumSwimming  6.1.24163.0.msi
