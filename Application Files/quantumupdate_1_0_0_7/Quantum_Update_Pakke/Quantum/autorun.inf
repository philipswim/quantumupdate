LabelRectValue = 280*310*523*923
SetupProgram = \Microsoft\VC_redist.x64_2015_2022.exe**
SetupWindow = Microsoft VC_redist.x64
TestFile = \Microsoft\VC_redist.x64_2015_2022.exe
Description = %B2Description.Text%
ErrorText = %B2Error.Text%

[Button3]
SetupLabel = %B3SetupLabel.Text%
LabelRectValue = 310*340*504*904
SetupProgram = \DRC\Swiss Timing - DRC Framework - Quantum.msi**
SetupWindow = DRC Setup Wizard
TestFile = \DRC\Swiss Timing - DRC Framework - Quantum.msi
