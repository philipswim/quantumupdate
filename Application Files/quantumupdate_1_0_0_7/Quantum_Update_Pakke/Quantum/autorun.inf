AlreadyRunningErrorText =

[Bitmaps]
16Color = setup\bitmap\INTRO256.BMP
256Color = setup\bitmap\INTRO256.BMP

[Strings]
QAQTitle.Text = Swiss Timing - Aquatics Software Installation

B0SetupLabel.Text = Installation procedure
B0Description.Text = Read important information about Quantum softwares installation
B0Error.Text = The USB key has probably be removed, please insert the USB Key labeled QUANTUM softwares installation.

B1SetupLabel.Text = Microsoft .NET 4.8 Framework
B1Description.Text = Install the Microsoft .NET 4.8 Framework
B1Error.Text = This configuration do not include the .NET Framework

B2SetupLabel.Text = Microsoft VC_redist.x64
B2Description.Text = Install the Microsoft VC_redist.x64
B2Error.Text = This configuration do not include the Microsoft VC_redist.x64

B3SetupLabel.Text = Install DRC Base libraries 6.1.24060.1 
B3Description.Text = Launch the SwissTiming DRC installation wizard.
B3Error.Text = This configuration do not include the DRC package.

B4SetupLabel.Text = Launch QUANTUM SW Application 6.1.24163.0
B4Description.Text = Launch the installation wizard.  
B4Error.Text = This configuration do not include the swimming application.

B5SetupLabel.Text = Open folder ARTISTIC SWIMMING
B5Description.Text = Launch the installation wizard.  
B5Error.Text = This configuration do not include the synchro swimming application.

B6SetupLabel.Text = Open folder DIVING Application
B6Description.Text = Launch the installation wizard.  
B6Error.Text = This configuration do not include the diving application.

B7SetupLabel.Text = Users manuals
B7Description.Text = Browse the USB Key through Manuals folder
B7Error.Text = The USB Key has probably be removed, please insert the USB Key labeled QUANTUM softwares installation.

B8SetupLabel.Text = QUANTUM USB Driver 2.12.24
B8Description.Text = Install the QUANTUM USB Driver
B8Error.Text = The USB Key has probably be removed, please insert the USB Key labeled QUANTUM softwares installation.

B9SetupLabel.Text = QUANTUM USB Driver Troubleshooting
B9Description.Text = Only required if the Sports Application cannot connect to the Quantum. Follow instruction from the upgade tool.
B9Error.Text = The USB Key has probably be removed, please insert the USB Key labeled QUANTUM softwares installation

B10SetupLabel.Text = EXIT
B10Description.Text = Click here to exit this installation wizard.


